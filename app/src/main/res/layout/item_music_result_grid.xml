<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:background="@color/surface_low"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="10dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="148dp">

        <View
            android:id="@+id/vLikedBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_music_liked_gradient"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivLikedIcon"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_thumb_up_liked"
            android:visibility="gone"
            app:tint="@android:color/white" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivTrackThumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/surface_high"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Small" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivPlaylistOfflineAll"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_offline_state_outline_muted"
                android:padding="4dp"
                android:src="@drawable/ic_check_small"
                android:visibility="gone"
                app:tint="@color/text_secondary" />

            <ImageView
                android:id="@+id/ivTrackMore"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="7dp"
                android:src="@drawable/ic_more_vert"
                app:tint="#CCFFFFFF" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/tvTrackTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="Playlist"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTrackSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Playlist"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <View
        android:id="@+id/vTrackDivider"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
