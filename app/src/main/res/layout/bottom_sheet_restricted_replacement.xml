<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/llRestrictedRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/black"
    android:paddingTop="16dp"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_drag_handle"
        android:layout_marginBottom="12dp" />

    <!-- Header: "Canción actual:" -->
    <TextView
        android:id="@+id/tvRestrictedHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Canción actual:"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="4dp" />

    <!-- Original track info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/ivOriginalTrackThumbnail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:background="#1A1A1A"
            android:layout_marginEnd="12dp"
            android:contentDescription="Original thumbnail" />

        <TextView
            android:id="@+id/tvOriginalTrackInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            tools:text="Track Title — Artist Name" />
    </LinearLayout>

    <!-- Loading state -->
    <LinearLayout
        android:id="@+id/llLoadingState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:visibility="visible">

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:indeterminate="true"
            android:indeterminateTintMode="src_atop"
            android:indeterminateTint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buscando alternativas…"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- Results RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvReplacementCandidates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:overScrollMode="never"
        android:clipToPadding="false" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/llEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No encontramos alternativas reproducibles."
            android:textColor="#999999"
            android:textSize="14sp"
            android:textAlignment="center" />

        <TextView
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reintentar"
            android:textColor="#4FC3F7"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>

    <!-- Undo replacement button -->
    <TextView
        android:id="@+id/btnUndoReplacement"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="Deshacer reemplazo"
        android:textColor="#888888"
        android:textSize="13sp"
        android:background="?attr/selectableItemBackground"
        android:visibility="gone" />

</LinearLayout>
