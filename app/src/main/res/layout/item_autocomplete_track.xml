<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/ivAutoCompleteThumb"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="12dp"
        android:background="@color/surface_high"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAutoCompleteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-black"
            android:includeFontPadding="false"
            android:maxLines="2"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAutoCompleteArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/inter_variable"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

    </LinearLayout>

    <ImageView
        android:id="@+id/ivAutoCompleteOffline"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/bg_offline_state_outline_muted"
        android:padding="4dp"
        android:src="@drawable/ic_check_small"
        android:visibility="invisible"
        app:tint="@color/text_secondary" />

    <ImageView
        android:id="@+id/ivAutoCompleteMore"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="8dp"
        android:src="@drawable/ic_more_vert"
        app:tint="@color/text_secondary" />

</LinearLayout>
