<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scannerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05060A">

    <!-- Full screen camera preview - no black bar -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewScanner"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:implementationMode="performance"
        app:scaleType="fillCenter" />

    <ImageView
        android:id="@+id/ivFreezeOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="Frame congelado"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Floating Import Images button at TOP RIGHT -->
    <LinearLayout
        android:id="@+id/actionImportImages"
        android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_scanner_import_images_pill"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="44dp"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivImportImages"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:tint="#FFFFFFFF" />

            <TextView
                android:id="@+id/tvImportImages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:fontFamily="@font/manrope_variable"
                android:gravity="center"
                android:text="Imagenes"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

    <!-- Result card at BOTTOM -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardScanResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="10dp"
        android:visibility="gone"
        app:cardBackgroundColor="#2A2D36"
        app:cardCornerRadius="22dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="16dp"
            android:paddingEnd="18dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_scanner"
                    app:tint="#FFFFFFFF" />

                <TextView
                    android:id="@+id/tvScanResultLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_variable"
                    android:textColor="#FFFFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvScanResultMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/inter_variable"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/btnCancelScan"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="8dp"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Cerrar resultado"
                    android:src="@drawable/ic_close"
                    app:tint="#99FFFFFF" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowScanResultValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tvScanResultValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_variable"
                    android:textColor="#E8EAEF"
                    android:textIsSelectable="false"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/ivScanResultCopy"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_circle_ripple"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_content_copy_18"
                    android:visibility="gone"
                    app:tint="#99FFFFFF" />

                <ImageView
                    android:id="@+id/ivScanResultOpen"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_open_external"
                    android:visibility="gone"
                    app:tint="#99FFFFFF" />

                <ImageView
                    android:id="@+id/ivScanResultChevron"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:visibility="gone"
                    app:tint="#99FFFFFF" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnScanResultViewOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/inter_variable"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="@string/scan_result_view_options"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Barrier to keep flashlight above scan result when visible -->
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrierScanResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="cardScanResult,bottomAnchor" />

    <!-- Invisible anchor at bottom for when card is hidden (closer to footer) -->
    <View
        android:id="@+id/bottomAnchor"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:layout_marginBottom="70dp"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Floating Flashlight button - moves above scan result when visible -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFlashlight"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:enabled="false"
        android:text="Encender la linterna"
        android:textAllCaps="false"
        android:textColor="#8A909D"
        app:backgroundTint="#565B64"
        app:cornerRadius="24dp"
        app:icon="@drawable/ic_flashlight_off"
        app:iconPadding="8dp"
        app:iconTint="#8A909D"
        app:layout_constraintBottom_toTopOf="@id/barrierScanResult"
        app:layout_goneMarginBottom="90dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
