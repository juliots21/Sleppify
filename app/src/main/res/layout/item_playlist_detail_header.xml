<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="480dp"
            android:layout_marginBottom="0dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageView
                android:id="@+id/ivPlaylistBackdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="1.0"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music" />

            <View
                android:id="@+id/vPlaylistBackdropScrim"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_playlist_backdrop_scrim" />

            <View
                android:id="@+id/vPlaylistBackdropBottomFade"
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_playlist_backdrop_bottom_fade" />

            <View
                android:id="@+id/vPlaylistBackdropAmoledFade"
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_playlist_backdrop_amoled_fade"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="34dp"
                android:paddingBottom="16dp">

                <FrameLayout
                    android:layout_width="320dp"
                    android:layout_height="wrap_content"
                    android:minHeight="200dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_playlist_cover_glow"
                        android:scaleX="1.06"
                        android:scaleY="1.06" />

                    <ImageView
                        android:id="@+id/ivPlaylistCover"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="200dp"
                        android:background="@color/surface_high"
                        android:scaleType="fitCenter"
                        android:adjustViewBounds="true"
                        android:maxHeight="320dp"
                        android:src="@drawable/ic_music" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvPlaylistName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Lista"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivGoogleProfile"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

                    <TextView
                        android:id="@+id/tvGoogleProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/inter_variable"
                        android:text="Tu cuenta"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPlaylistInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/inter_variable"
                    android:maxLines="2"
                    android:text="Lista"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnListenNow"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:backgroundTint="@android:color/white"
                        android:fontFamily="@font/manrope_variable"
                        android:minWidth="168dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Reproducir"
                        android:textAllCaps="false"
                        android:textColor="#101010"
                        android:textFontWeight="800"
                        android:textStyle="bold"
                        app:cornerRadius="28dp"
                        app:icon="@android:drawable/ic_media_play"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="#101010"
                        app:rippleColor="#33FFFFFF" />

                    <LinearLayout
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/btnShuffle"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_playlist_action_white"
                            android:padding="14dp"
                            android:src="@drawable/ic_shuffle_custom"
                            app:tint="#101010" />

                        <View
                            android:id="@+id/vHeaderShuffleIndicator"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:layout_marginTop="3dp"
                            android:background="@drawable/bg_mode_indicator_dot"
                            android:visibility="gone" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnDownload"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_playlist_action_white"
                        android:padding="18dp"
                        android:src="@drawable/ic_download_bold"
                        app:tint="#101010" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTracksState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:fontFamily="@font/inter_variable"
                    android:text="Cargando canciones..."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/llOfflineLoadingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:layout_marginStart="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/pbOfflineDownload"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/stitch_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/inter_variable"
            android:text="Descargando..."
            android:textColor="@color/stitch_blue"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
