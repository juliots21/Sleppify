<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/llPlaylistHeaderRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:focusable="true"
    android:focusableInTouchMode="true">

        <FrameLayout
            android:id="@+id/flPlaylistHeaderContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="0dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageView
                android:id="@+id/ivPlaylistBackdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="1.0"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music" />

            <View
                android:id="@+id/vPlaylistBackdropScrim"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_playlist_backdrop_scrim" />

            <View
                android:id="@+id/vPlaylistBackdropBottomFade"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_playlist_backdrop_bottom_fade" />

            <View
                android:id="@+id/vPlaylistBackdropAmoledFade"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_playlist_backdrop_amoled_fade"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <FrameLayout
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_playlist_cover_glow"
                        android:scaleX="1.06"
                        android:scaleY="1.06" />

                    <ImageView
                        android:id="@+id/ivPlaylistCover"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_music" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvPlaylistName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="Lista"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivGoogleProfile"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

                    <TextView
                        android:id="@+id/tvGoogleProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/inter_variable"
                        android:text="Tu cuenta"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPlaylistInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/inter_variable"
                    android:maxLines="2"
                    android:text="Lista"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnListenNow"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:backgroundTint="@android:color/white"
                        android:fontFamily="@font/manrope_variable"
                        android:minWidth="168dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="Reproducir"
                        android:textAllCaps="false"
                        android:textColor="#101010"
                        android:textFontWeight="800"
                        android:textStyle="bold"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        app:cornerRadius="28dp"
                        app:icon="@drawable/ic_player_play"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="#101010"
                        app:rippleColor="#33FFFFFF" />



                    <ImageButton
                        android:id="@+id/btnDownload"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_playlist_action_white"
                        android:padding="18dp"
                        android:src="@drawable/ic_download_bold"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        app:tint="#101010" />
                </LinearLayout>

            </LinearLayout>
        </FrameLayout>


</LinearLayout>
