<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:minHeight="84dp"
    android:paddingStart="2dp"
    android:paddingEnd="2dp">

    <LinearLayout
        android:id="@+id/llContentRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp">

            <View
                android:id="@+id/vLikedBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_music_liked_gradient"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivLikedIcon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_thumb_up_liked"
                android:visibility="gone"
                app:tint="@android:color/white" />

            <ImageView
                android:id="@+id/ivTrackThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music" />

            <FrameLayout
                android:id="@+id/llNowPlayingOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <com.example.sleppify.AnimatedEqualizerView
                    android:id="@+id/animatedEq"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="4dp"
                    app:barColor="@color/stitch_blue" />
            </FrameLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTrackTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Track"
                android:textColor="@color/text_primary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvTrackSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Playlist"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivPlaylistOfflineAll"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_offline_state_outline_muted"
                android:padding="4dp"
                android:src="@drawable/ic_check_small"
                android:visibility="gone"
                app:tint="@color/text_secondary" />

            <ImageView
                android:id="@+id/ivTrackMore"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:src="@drawable/ic_more_vert"
                app:tint="#A8FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/vTrackDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/llContentRow"
        android:layout_marginStart="76dp"
        android:layout_marginTop="8dp"
        android:background="#1FFFFFFF" />

</RelativeLayout>
