<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#191B22"
    app:cardCornerRadius="24dp"
    app:cardElevation="12dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <!-- Edit Action -->
        <LinearLayout
            android:id="@+id/llTaskTooltipEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_edit_24"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvTaskTooltipEdit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:fontFamily="@font/manrope_variable"
                android:textStyle="bold"
                android:text="Editar"
                android:textColor="#E2E2EB"
                android:textSize="14sp" />

        </LinearLayout>

        <View
            android:id="@+id/dividerTaskTooltipEdit"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:background="#2C2F38" />

        <!-- Set Time Action -->
        <LinearLayout
            android:id="@+id/llTaskTooltipSetTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_time_24"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvTaskTooltipSetTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:fontFamily="@font/manrope_variable"
                android:textStyle="bold"
                android:text="@string/agenda_task_menu_set_time"
                android:textColor="#E2E2EB"
                android:textSize="14sp" />

        </LinearLayout>

        <View
            android:id="@+id/dividerTaskTooltip"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:background="#2C2F38" />

        <!-- Delete Action -->
        <LinearLayout
            android:id="@+id/llTaskTooltipDelete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_delete_24"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvTaskTooltipDelete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:fontFamily="@font/manrope_variable"
                android:textStyle="bold"
                android:text="@string/agenda_task_menu_delete"
                android:textColor="#C3C6D5"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
