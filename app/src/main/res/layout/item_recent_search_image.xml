<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/flImageContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/surface_high">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/ivRecentSearchImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:alpha="0"
                android:contentDescription="Miniatura de búsqueda reciente" />

            <!-- Loading placeholder -->
            <View
                android:id="@+id/vLoadingPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/surface_high" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Song title below image -->
    <TextView
        android:id="@+id/tvRecentSearchTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:fontFamily="@font/inter_variable"
        android:maxLines="1"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>
