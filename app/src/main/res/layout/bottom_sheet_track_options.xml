<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="20dp"
    android:paddingEnd="16dp"
    android:paddingBottom="24dp">

    <!-- Header info -->
    <LinearLayout
        android:id="@+id/llBsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">
        <ImageView
            android:id="@+id/ivBsTrackArt"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:background="@color/surface_high"
            />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:id="@+id/tvBsTrackTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:maxLines="2"
                android:ellipsize="end"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvBsTrackSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artist"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/inter_variable"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/ivBsOfflineState"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_offline_state_filled_primary"
            android:padding="4dp"
            android:src="@drawable/ic_check_small"
            android:visibility="gone"
            app:tint="@color/surface_dark"/>
    </LinearLayout>

    <!-- Top 3 buttons container -->
    <LinearLayout
        android:id="@+id/llBsTopActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:weightSum="3"
        android:layout_marginBottom="16dp">

        <!-- Button 1: Play Next -->
        <LinearLayout
            android:id="@+id/btnBsPlayNext"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_bs_action_button">
                <ImageView
                    android:id="@+id/ivBsPlayNextIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_stream_play_next"
                    app:tint="@android:color/white"/>
            </FrameLayout>
            <TextView
                android:id="@+id/tvBsPlayNextLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reproducir a\ncontinuación"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/inter_variable"
                android:gravity="center"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Button 2: Add to Queue / Add to Playlist (Depends on context) -->
        <LinearLayout
            android:id="@+id/btnBsAddPrimary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_bs_action_button">
                <ImageView
                    android:id="@+id/ivBsAddPrimary"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_stream_queue_add"
                    app:tint="@android:color/white"/>
            </FrameLayout>
            <TextView
                android:id="@+id/tvBsAddPrimary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agregar a\nla fila"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/inter_variable"
                android:gravity="center"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Button 3: Share -->
        <LinearLayout
            android:id="@+id/btnBsShare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_bs_action_button">
                <ImageView
                    android:id="@+id/ivBsShareIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_playlist_share"
                    app:tint="@android:color/white"/>
            </FrameLayout>
            <TextView
                android:id="@+id/tvBsShareLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Compartir"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="@font/inter_variable"
                android:gravity="center"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1FFFFFFF"
        android:layout_marginBottom="8dp"/>

    <!-- Bottom list actions -->
    <LinearLayout
        android:id="@+id/llBsListActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 1. Reproducir a continuación -->
        <LinearLayout
            android:id="@+id/btnBsPlayPlaylist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="14dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">
            <ImageView
                android:id="@+id/ivBsPlayPlaylist"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_bs_play_next_yt"
                app:tint="@android:color/white"/>
            <TextView
                android:id="@+id/tvBsPlayPlaylist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Reproducir a continuación"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/inter_variable"/>
        </LinearLayout>

        <!-- 2. Agregar a la fila -->
        <LinearLayout
            android:id="@+id/btnBsAddToQueue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="14dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">
            <ImageView
                android:id="@+id/ivBsAddToQueue"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_bs_add_queue_yt"
                app:tint="@android:color/white"/>
            <TextView
                android:id="@+id/tvBsAddToQueue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Agregar a la fila"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/inter_variable"/>
        </LinearLayout>

        <!-- 3. Añadir a playlist -->
        <LinearLayout
            android:id="@+id/btnBsFavorite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="14dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/ivBsFavorite"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_stream_queue_add"
                app:tint="@android:color/white"/>
            <TextView
                android:id="@+id/tvBsFavorite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Añadir a playlist"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/inter_variable"/>
        </LinearLayout>

        <!-- 4. Radio -->
        <LinearLayout
            android:id="@+id/btnBsPlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="14dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">
            <ImageView
                android:id="@+id/ivBsPlay"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_bs_radio"
                app:tint="@android:color/white"/>
            <TextView
                android:id="@+id/tvBsPlayLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Radio"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/inter_variable"/>
        </LinearLayout>

        <!-- 5. Reemplazar -->
        <LinearLayout
            android:id="@+id/btnBsReplace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="14dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">
            <ImageView
                android:id="@+id/ivBsReplace"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_player_repeat"
                app:tint="@android:color/white"/>
            <TextView
                android:id="@+id/tvBsReplace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Reemplazar"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/inter_variable"/>
        </LinearLayout>

        <!-- 6. Borrar de la playlist -->
        <LinearLayout
            android:id="@+id/btnBsDownload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="14dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">
            <ImageView
                android:id="@+id/ivBsDownload"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_delete_modern"
                app:tint="@android:color/white"/>
            <TextView
                android:id="@+id/tvBsDownload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Borrar de la playlist"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/inter_variable"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
