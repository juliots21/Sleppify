<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="vertical"
    android:paddingTop="5dp"
    android:paddingBottom="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="72dp"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp">

            <View
                android:id="@+id/vLikedBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivLikedIcon"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivTrackThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTrackTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/manrope_variable"
                android:maxLines="2"
                android:text="Título"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvTrackSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:fontFamily="@font/inter_variable"
                android:maxLines="1"
                android:text="Canción • Artista"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivPlaylistOfflineAll"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivTrackMore"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_more_vert"
            app:tint="#D8FFFFFF" />
    </LinearLayout>

    <View
        android:id="@+id/vTrackDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="76dp"
        android:layout_marginTop="6dp"
        android:background="#16FFFFFF" />

</LinearLayout>
