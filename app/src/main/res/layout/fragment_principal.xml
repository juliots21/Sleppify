<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootPrincipal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <!-- Fragment-owned brand header (replaces activity topAppBar for this module) -->
    <LinearLayout
        android:id="@+id/llFragBrandHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        android:elevation="30dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="0dp"
        android:paddingBottom="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvFragBrandTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="10dp"
            android:gravity="start|center_vertical"
            android:minHeight="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="10dp"
            android:paddingVertical="2dp"
            android:text="@string/header_brand_title"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/btnFragHeaderSearch"
            android:layout_width="41.5dp"
            android:layout_height="41.5dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Buscar"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:padding="6dp"
            android:src="@drawable/ic_search"
            app:tint="@android:color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFragSignIn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/inter_variable"
            android:text="Iniciar sesión"
            android:textAllCaps="false"
            android:textColor="#1F2B42"
            android:textSize="13sp"
            android:visibility="gone"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_google_logo"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconSize="18dp"
            app:iconTint="@null"
            app:rippleColor="#2200419E" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/btnFragProfilePhoto"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@string/header_action_settings"
            android:focusable="true"
            android:padding="0dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvPrincipalContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llFragBrandHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingBottom="16dp">

            <!-- Section header: Google profile photo + Accesos directos -->
            <LinearLayout
                android:id="@+id/llShortcutsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivShortcutProfilePhoto"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@color/surface_high"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

                <TextView
                    android:id="@+id/tvShortcutsLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_variable"
                    android:text="Accesos directos"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivShortcutsMore"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vpShortcuts"
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:clipToPadding="false"
                android:overScrollMode="never" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabDotsShortcuts"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent"
                app:tabBackground="@drawable/selector_dot_indicator"
                app:tabGravity="center"
                app:tabIndicator="@null"
                app:tabIndicatorHeight="0dp"
                app:tabMaxWidth="8dp"
                app:tabMinWidth="8dp"
                app:tabPaddingEnd="5dp"
                app:tabPaddingStart="5dp" />

            <!-- Section: Mixes para ti (generic) -->
            <TextView
                android:id="@+id/tvMixesLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_variable"
                android:paddingHorizontal="4dp"
                android:paddingTop="20dp"
                android:paddingBottom="10dp"
                android:text="Mixes para ti"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMixes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <TextView
                android:id="@+id/tvMixesEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_variable"
                android:gravity="center"
                android:paddingHorizontal="32dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:text="Inicia sesión en YouTube Music para ver tus mixes personalizados"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Section: Mis Mixes (personal daily mixes) -->
            <TextView
                android:id="@+id/tvPersonalMixesLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_variable"
                android:paddingHorizontal="4dp"
                android:paddingTop="20dp"
                android:paddingBottom="10dp"
                android:text="Escucha estos mixes creados para ti"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPersonalMixes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:visibility="gone" />

            <!-- Section: Covers y Remixes -->
            <LinearLayout
                android:id="@+id/llCoversHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp"
                android:paddingTop="20dp"
                android:paddingBottom="10dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvCoversLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_variable"
                    android:text="Covers y remixes"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnCoversPlayAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_variable"
                    android:text="Reproducir todo"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="8dp" />
            </LinearLayout>

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vpCovers"
                android:layout_width="match_parent"
                android:layout_height="288dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:visibility="gone" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabDotsCovers"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent"
                app:tabBackground="@drawable/selector_dot_indicator"
                app:tabGravity="center"
                app:tabIndicator="@null"
                app:tabIndicatorHeight="0dp"
                app:tabMaxWidth="8dp"
                app:tabMinWidth="8dp"
                app:tabPaddingEnd="5dp"
                app:tabPaddingStart="5dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>
