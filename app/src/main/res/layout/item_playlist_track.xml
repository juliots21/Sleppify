<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootTrackRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_playlist_track_default"
    android:minHeight="74dp"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="2dp"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="wrap_content"
            android:minHeight="44dp">

            <ImageView
                android:id="@+id/ivTrackArt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_high"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:maxHeight="64dp"
                android:src="@drawable/ic_music" />

            <LinearLayout
                android:id="@+id/llNowPlayingOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#55233972"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_equalizer"
                    app:tint="@color/stitch_blue" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTrackTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/manrope_variable"
                    android:maxLines="1"
                    android:text="Canción"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTrackSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:fontFamily="@font/inter_variable"
                android:maxLines="1"
                android:text="Artista • 3:42"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivOfflineState"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/bg_offline_state_outline_muted"
                android:padding="4dp"
                android:src="@drawable/ic_check_small"
                app:tint="@color/text_secondary" />

            <ImageView
                android:id="@+id/ivMore"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:src="@drawable/ic_more_vert"
                app:tint="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/flOfflineProgress"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="6dp"
        android:background="@color/surface_high"
        android:visibility="gone">


        <View
            android:id="@+id/vOfflineProgressFill"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/stitch_blue"
            android:scaleX="0" />
    </FrameLayout>

</LinearLayout>
