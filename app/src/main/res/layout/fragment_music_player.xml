<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingHorizontal="24dp"
    android:paddingTop="8dp"
    android:paddingBottom="0dp"
    tools:context=".MusicPlayerFragment">

    <TextView
        android:id="@+id/tvLibraryTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Biblioteca"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <HorizontalScrollView
        android:id="@+id/hsvLibraryFilters"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLibraryTitle">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_music_chip_active"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Playlists"
                android:textColor="#13254A"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:alpha="0.48"
                android:background="@drawable/bg_music_chip_inactive"
                android:clickable="false"
                android:enabled="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Artists"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:alpha="0.48"
                android:background="@drawable/bg_music_chip_inactive"
                android:clickable="false"
                android:enabled="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Albums"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:alpha="0.48"
                android:background="@drawable/bg_music_chip_inactive"
                android:clickable="false"
                android:enabled="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Podcasts"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/llLibrarySortRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hsvLibraryFilters">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Reproducido recientemente"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivLibraryViewToggle"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/bg_library_view_toggle"
            android:clickable="true"
            android:focusable="true"
            android:padding="7dp"
            android:src="@drawable/ic_view_grid_mode"
            app:tint="@color/text_secondary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llMusicState"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llLibrarySortRow">

        <ProgressBar
            android:id="@+id/progressMusic"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvMusicState"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llLibraryEmptyState"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/llMiniPlayer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnYoutubeLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/inter_variable"
            android:text="Sign in with Google"
            android:textAllCaps="false"
            android:textColor="#1F2B42"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_google_logo"
            app:iconGravity="textStart"
            app:iconPadding="14dp"
            app:iconTint="@null"
            app:rippleColor="#2200419E" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMusicResults"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:clipToPadding="false"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/llMiniPlayer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llMusicState"
        tools:listitem="@layout/item_music_result" />

    <LinearLayout
        android:id="@+id/llSearchOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/llMiniPlayer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/llSearchRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMusicQuery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionSearch"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSearchMusic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buscar" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabSearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buscar" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabLibrary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Biblioteca" />
        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/hsvFilterChips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChipVideos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Videos" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChipSongs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Canciones" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChipArtists"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Artistas" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChipPlaylists"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Playlists" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/llFeaturedResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivFeaturedThumb"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:src="@drawable/ic_music" />

            <TextView
                android:id="@+id/tvFeaturedTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Featured" />

            <TextView
                android:id="@+id/tvFeaturedSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subtitle" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFeaturedPlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Play" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFeaturedSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llMiniPlayer"
        android:layout_width="0dp"
        android:layout_height="84dp"
        android:layout_marginStart="-24dp"
        android:layout_marginEnd="-24dp"
        android:layout_marginBottom="-8dp"
        android:background="@drawable/bg_playlist_footer_extension"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="0dp"
        android:paddingTop="8dp"
        android:paddingEnd="0dp"
        android:paddingBottom="6dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivMiniPlayerArt"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@color/surface_high"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Small" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMiniPlayerTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/manrope_variable"
                    android:maxLines="1"
                    android:text="Selecciona una canción"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMiniPlayerSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_variable"
                    android:maxLines="1"
                    android:text=""
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnMiniPlayPause"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:src="@drawable/ic_mini_play"
                app:tint="@color/stitch_blue" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/sbMiniPlayerProgress"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:layout_marginTop="4dp"
            android:enabled="false"
            android:max="1000"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:progress="0"
            android:progressTint="@color/stitch_blue"
            android:splitTrack="false"
            android:thumb="@null"
            android:thumbTint="@android:color/transparent" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
