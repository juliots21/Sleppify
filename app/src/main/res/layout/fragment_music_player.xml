<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeLibraryRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:clipChildren="false"
    android:clipToPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingHorizontal="24dp"
    android:paddingTop="8dp"
    android:paddingBottom="0dp"
    tools:context=".MusicPlayerFragment">



    <LinearLayout
        android:id="@+id/llLibraryInlineSearch"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:elevation="4dp"
        android:background="@drawable/bg_music_chip_inactive"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="@color/text_secondary" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etLibraryQuickSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Buscar canciones"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingStart="8dp"
            android:paddingEnd="4dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="13sp" />

            <ImageView
                android:id="@+id/ivLibraryQuickClear"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:alpha="0.88"
                android:background="@drawable/bg_library_inline_clear"
                android:clickable="true"
                android:contentDescription="Limpiar búsqueda"
                android:focusable="true"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:visibility="gone"
                app:tint="@color/text_secondary" />
    </LinearLayout>





    <HorizontalScrollView
        android:id="@+id/hsvFilterChips"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llLibraryInlineSearch">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChipSongs"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Canciones"
                android:textSize="12sp"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChipVideos"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:text="Videos"
                android:textSize="12sp"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChipArtists"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:text="Artistas"
                android:textSize="12sp"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChipPlaylists"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:text="Playlists"
                android:textSize="12sp"
                app:cornerRadius="20dp" />
        </LinearLayout>
    </HorizontalScrollView>



    <!-- Search Overlay -->
    <LinearLayout
        android:id="@+id/llSearchOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/surface_dark"
        android:elevation="6dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/llMiniPlayer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llLibraryInlineSearch">

        <LinearLayout
            android:id="@+id/llSearchRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_search_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMusicQuery"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Canción, artista, video..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSearchMusic"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:icon="@android:drawable/ic_menu_search"
                app:iconTint="@color/stitch_blue" />
        </LinearLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgSearchSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="8dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/llMusicState"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@color/surface_dark"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hsvFilterChips">

        <ProgressBar
            android:id="@+id/progressMusic"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:indeterminateTint="@android:color/white"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvMusicState"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llLibraryEmptyState"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/llMiniPlayer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnYoutubeLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/inter_variable"
            android:text="Sign in with Google"
            android:textAllCaps="false"
            android:textColor="#1F2B42"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_google_logo"
            app:iconGravity="textStart"
            app:iconPadding="14dp"
            app:iconTint="@null"
            app:rippleColor="#2200419E" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llFeaturedResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:background="@color/surface_dark"
        android:elevation="4dp"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llMusicState">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivFeaturedThumb"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:background="@color/surface_high"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Small" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvFeaturedTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/manrope_variable"
                    android:maxLines="2"
                    android:text="CORA DE HIELO"
                    android:textAllCaps="true"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvFeaturedSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter_variable"
                    android:maxLines="1"
                    android:text="Canción • Artista"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFeaturedPlay"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:fontFamily="@font/inter_variable"
                android:text="Reproducir"
                android:textAllCaps="false"
                android:textColor="#111319"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="@color/white"
                app:cornerRadius="23dp"
                app:icon="@drawable/ic_player_play"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconTint="#111319" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFeaturedSave"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:fontFamily="@font/inter_variable"
                android:text="Compartir"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="23dp"
                app:icon="@android:drawable/ic_menu_share"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconTint="@color/text_primary"
                app:rippleColor="#2FFFFFFF"
                app:strokeColor="@color/surface_high"
                app:strokeWidth="2dp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMusicResults"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:clipToPadding="false"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/llMiniPlayer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llFeaturedResult"
        tools:listitem="@layout/item_music_result" />



        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabAddPlaylist"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="0dp"
            android:layout_marginBottom="16dp"
            android:contentDescription="Nueva Playlist"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:backgroundTint="@color/stitch_blue"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@android:color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
