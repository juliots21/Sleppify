<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <FrameLayout
        android:id="@+id/webSessionContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <FrameLayout
        android:id="@+id/loginOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black">

        <!-- Fondo animado -->
        <ImageView
            android:id="@+id/imgAmbient"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/bg_yt_gradient"
            android:scaleType="centerCrop" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center_horizontal">

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Logo circular de YouTube Music -->
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_yt_music_logo"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Conecta con YouTube Music"
                    android:textColor="@android:color/white"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sleppify utiliza YouTube Music para potenciar tu biblioteca musical. Inicia sesión para acceder a:"
                    android:textColor="#B3B3B3"
                    android:textSize="15sp"
                    android:textAlignment="center"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="32dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check_gray" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tus playlists y canciones favoritas"
                        android:textColor="#E0E0E0"
                        android:textSize="15sp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check_gray" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="El catálogo completo sin límites"
                        android:textColor="#E0E0E0"
                        android:textSize="15sp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check_gray" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reproducción en segundo plano offline"
                        android:textColor="#E0E0E0"
                        android:textSize="15sp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check_gray" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descargas sin límite"
                        android:textColor="#E0E0E0"
                        android:textSize="15sp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="48dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check_gray" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Crossfade entre canciones y más"
                        android:textColor="#E0E0E0"
                        android:textSize="15sp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOverlayLogin"
                    android:layout_width="wrap_content"
                    android:minWidth="310dp"
                    android:layout_height="60dp"
                    android:text="Continuar en YouTube Music"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@null"
                    android:background="@drawable/bg_youtube_button"
                    app:icon="@drawable/ic_yt_music_logo"
                    app:iconGravity="textStart"
                    app:iconPadding="10dp"
                    app:iconSize="38dp"
                    app:iconTint="@null"
                    android:paddingStart="16dp"
                    android:paddingEnd="20dp"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:elevation="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sleppify es un proyecto de código abierto. No interceptamos, recopilamos ni almacenamos tus credenciales o datos personales de uso. Todo el proceso de sesión ocurre directamente y de forma segura en los servidores de Google y YouTube."
                    android:textColor="#808080"
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="16dp"
                    android:lineSpacingExtra="3dp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

            </LinearLayout>
        </ScrollView>
    </FrameLayout>
</FrameLayout>
